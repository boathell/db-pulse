{
  "name": "db-pulse",
  "version": "0.1.0",
  "private": false,
  "description": "Evidence-backed intelligence and decision support for China's database industry.",
  "author": "boathell",
  "homepage": "https://boathell.github.io/db-pulse/",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/boathell/db-pulse.git"
  },
  "bugs": {
    "url": "https://github.com/boathell/db-pulse/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/cli/serve.ts",
    "start": "tsx src/cli/serve.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "db:snapshot": "tsx src/cli/snapshot.ts",
    "collect": "tsx src/cli/collect.ts",
    "sources:audit": "tsx src/cli/audit-sources.ts",
    "sources:proposal:validate": "tsx src/cli/validate-source-proposal.ts",
    "sources:proposal:import": "tsx src/cli/import-source-proposal.ts",
    "sources:health:issue": "tsx src/cli/render-source-health-issue.ts",
    "weekly:issue": "tsx src/cli/render-weekly-brief.ts",
    "public:fingerprint": "tsx src/cli/public-content-fingerprint.ts",
    "repair:provenance": "tsx src/cli/repair-provenance.ts",
    "repair:activations": "tsx src/cli/repair-activations.ts",
    "repair:review-noise": "tsx src/cli/repair-review-noise.ts",
    "activate": "tsx src/cli/activate.ts",
    "activate:auto": "tsx src/cli/auto-activate.ts",
    "observe:sources": "tsx src/cli/observe-sources.ts",
    "ops:reconcile": "tsx src/cli/autonomous-operations.ts",
    "scout:generate": "tsx src/cli/scout.ts",
    "evaluate:system": "tsx src/cli/evaluate.ts",
    "evolve": "tsx src/cli/evolve.ts",
    "monitor": "tsx src/cli/monitor-cli.ts",
    "monitor:check": "tsx src/cli/monitor-check.ts",
    "release:check": "tsx src/cli/release-notes.ts --check",
    "release:notes": "tsx src/cli/release-notes.ts",
    "export": "tsx src/cli/export.ts",
    "privacy:scan": "tsx scripts/scan-static-output.ts",
    "auto:publish": "tsx src/cli/auto-publish.ts",
    "check": "npm run lint && npm run typecheck && npm test && npm run export && npm run privacy:scan"
  },
  "keywords": [
    "database-industry",
    "database-intelligence",
    "timeline",
    "dba",
    "data-architecture",
    "industry-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.4.1",
    "fast-xml-parser": "^5.3.3",
    "fastify": "^5.6.2",
    "kysely": "^0.28.8",
    "mysql2": "^3.15.3",
    "undici": "^7.28.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "esbuild": "^0.28.1",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
