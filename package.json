{
  "name": "agent-pulse",
  "version": "0.2.0",
  "private": false,
  "description": "A curated AI industry intelligence timeline — signal, not noise.",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsx watch src/cli/serve.ts",
    "start": "tsx src/cli/serve.ts",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/cli/migrate.ts",
    "db:seed": "tsx src/cli/seed.ts",
    "collect": "tsx src/cli/collect.ts",
    "export": "tsx src/cli/export.ts",
    "check": "npm run lint && npm run typecheck && npm test && npm run export"
  },
  "keywords": [
    "ai-news",
    "ai-intelligence",
    "timeline",
    "llm",
    "industry-analysis"
  ],
  "license": "MIT",
  "dependencies": {
    "@fastify/cors": "^11.1.0",
    "@fastify/static": "^8.3.0",
    "better-sqlite3": "^12.4.1",
    "fast-xml-parser": "^5.3.3",
    "fastify": "^5.6.2",
    "kysely": "^0.28.8",
    "mysql2": "^3.15.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^24.10.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^4.0.7"
  }
}
